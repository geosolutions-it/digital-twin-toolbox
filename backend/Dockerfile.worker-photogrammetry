# Builder stage: worker venv (/app/.venv) + the OpenSfM conda env + compiled OpenSfM/texrecon.
# Split into cache-friendly layers; toolchain/headers never reach the final image.
# Order: the slow, rarely-changing native builds first; the dependency sync (changes with
# pyproject/uv.lock) last, so a dep bump only reruns the cheap uv layer.
FROM python:3.11-slim AS builder

COPY --from=ghcr.io/astral-sh/uv:0.9.26 /uv /uvx /bin/

ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy

WORKDIR /app/

ARG OPENSFM_ENV=opensfm
ENV MAMBA_ROOT_PREFIX=/root/micromamba

# micromamba (only for the OpenSfM conda env)
RUN apt-get update \
    && apt-get install -y --no-install-recommends bzip2 ca-certificates curl \
    && cd / \
    && curl -Ls https://micro.mamba.pm/api/micromamba/linux-64/1.5.10 | tar -xvj bin/micromamba \
    && /bin/micromamba config append channels conda-forge \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# build toolchain + headers (builder only)
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        cmake \
        git \
        libceres-dev \
        libeigen3-dev \
        libjpeg-dev \
        libopencv-dev \
        libpng-dev \
        libtbb-dev \
        libtiff-dev

# OpenSfM in its own conda env (opencv pinned <5 so calib3d is found)
RUN mkdir /source/ \
    && cd /source/ \
    && git clone --recursive https://github.com/mapillary/OpenSfM.git \
    && cd /source/OpenSfM/ \
    && git checkout 8074f9fbc67ddcfc0f1726f69db288365a83ad95 \
    && /bin/micromamba create -n "${OPENSFM_ENV}" -y --file /source/OpenSfM/conda.yml "libopencv<5" "py-opencv<5" \
    && /bin/micromamba run -n "${OPENSFM_ENV}" bash -ec '\
        cmake -S opensfm/src -B cmake_build \
          -DPYTHON_EXECUTABLE="$(which python)" \
          -DOPENSFM_BUILD_TESTS=OFF && \
        cmake --build cmake_build -j"$(nproc)" \
    ' \
    && rm -rf /source/OpenSfM/cmake_build /source/OpenSfM/.git

# mvs-texturing (texrecon binary)
RUN cd / \
    && git clone https://github.com/santerioksanen/mvs-texturing.git \
    && cd mvs-texturing \
    && git checkout "feature/tbb-depend" \
    && mkdir build && cd build \
    && cmake .. \
    && make \
    && rm -rf /mvs-texturing/.git

# worker python deps -> /app/.venv (no conda; the worker imports only pip packages).
# Last so dependency changes don't invalidate the native-build layers above.
ARG INSTALL_DEV=false
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    if [ "$INSTALL_DEV" = "true" ]; then \
      uv sync --frozen --no-install-workspace --group worker --group photogrammetry --group dev; \
    else \
      uv sync --frozen --no-install-workspace --no-dev --group worker --group photogrammetry; \
    fi


# Final stage: runtime libs + built artifacts only (no toolchain, no uv, no -dev libs, no ddt env).
FROM python:3.11-slim

ARG OPENSFM_ENV=opensfm

ENV PYTHONPATH=/app
ENV MAMBA_ROOT_PREFIX=/root/micromamba
ENV PATH="/app/.venv/bin:/bin:${PATH}"

WORKDIR /app/

# runtime libs: open3d/opencv need libGL+glib; texrecon needs tbb/png/jpeg/tiff/gomp
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        libgl1 \
        libglib2.0-0 \
        libgomp1 \
        libtbb12 \
        libpng16-16 \
        libjpeg62-turbo \
        libtiff6 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/.venv /app/.venv
COPY --from=builder /bin/micromamba /bin/micromamba
COPY --from=builder /root/micromamba/envs/${OPENSFM_ENV} /root/micromamba/envs/${OPENSFM_ENV}
COPY --from=builder /source/OpenSfM /source/OpenSfM
COPY --from=builder /mvs-texturing/build /mvs-texturing/build

COPY ./scripts/ /app/
COPY ./alembic.ini /app/
COPY ./prestart.sh /app/
COPY ./tests-start.sh /app/
COPY ./app /app/app

# smoke-test the worker deps (app modules import settings, which needs runtime env, so we
# check the libraries directly instead).
RUN python -c "import open3d, cv2, numpy, pyproj, psutil, celery, sqlmodel; print('py deps OK')"

ENTRYPOINT ["bash", "-c"]
