FROM python:3.11-slim

COPY --from=ghcr.io/astral-sh/uv:0.9.26 /uv /uvx /bin/

ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy
ENV PYTHONPATH=/app

WORKDIR /app/

ARG DDT_ENV=ddt
ARG OPENSFM_ENV=opensfm

ENV MAMBA_ROOT_PREFIX=/root/micromamba
ENV PATH="/root/micromamba/envs/${DDT_ENV}/bin:/bin:${PATH}"

RUN apt-get update \
    && apt-get install -y --no-install-recommends bzip2 ca-certificates curl \
    && cd / \
    && curl -Ls https://micro.mamba.pm/api/micromamba/linux-64/1.5.10 | tar -xvj bin/micromamba \
    && /bin/micromamba config append channels conda-forge \
    && /bin/micromamba create -n "${DDT_ENV}" python=3.11 -y \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    uv sync --frozen --no-install-workspace --no-dev --group worker --group mesh --group photogrammetry \
    --python /root/micromamba/envs/${DDT_ENV}/bin/python

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        cmake \
        git \
        libceres-dev \
        libeigen3-dev \
        libjpeg-dev \
        libopencv-dev \
        libpng-dev \
        libtbb-dev \
        libtiff-dev \
    && mkdir /source/ \
    && cd /source/ \
    && git clone --recursive https://github.com/mapillary/OpenSfM.git \
    && cd /source/OpenSfM/ \
    && git checkout 8074f9fbc67ddcfc0f1726f69db288365a83ad95 \
    && /bin/micromamba create -n "${OPENSFM_ENV}" -y --file /source/OpenSfM/conda.yml \
    && /bin/micromamba run -n "${OPENSFM_ENV}" bash -ec '\
        cmake -S opensfm/src -B cmake_build \
          -DPYTHON_EXECUTABLE="$(which python)" \
          -DOPENSFM_BUILD_TESTS=OFF && \
        cmake --build cmake_build -j"$(nproc)" \
    ' \
    && cd / \
    && git clone https://github.com/santerioksanen/mvs-texturing.git \
    && cd mvs-texturing \
    && git checkout "feature/tbb-depend" \
    && mkdir build && cd build \
    && cmake .. \
    && make \
    && apt-get purge -y --auto-remove build-essential cmake git \
    && apt-get autoremove -y \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* /source/OpenSfM/cmake_build

COPY ./scripts/ /app/
COPY ./alembic.ini /app/
COPY ./prestart.sh /app/
COPY ./tests-start.sh /app/
COPY ./app /app/app

RUN mv /app/celery-reload.sh /celery-reload.sh && \
    mv /app/celery.sh /celery.sh && \
    chmod +x /celery-reload.sh && \
    chmod +x /celery.sh

ENTRYPOINT ["bash", "-c"]
